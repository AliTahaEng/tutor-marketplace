# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_FEATURED_PRICE_ID=price_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0

# Sentry (optional — leave blank to disable)
NEXT_PUBLIC_SENTRY_DSN=

# SendGrid email (optional — leave blank to disable emails)
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@tutorqatar.com

# Upstash Redis rate limiting (optional — falls back to in-memory if not set)
# Create free DB at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
