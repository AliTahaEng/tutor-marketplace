# Supabase (use EXPO_PUBLIC_ prefix — Expo does NOT recognize NEXT_PUBLIC_)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Web app URL — for opening payment and review pages in the in-app browser
# Local dev: http://localhost:3000  |  Production: https://tutorqatar.com
EXPO_PUBLIC_APP_URL=http://localhost:3000
